#!/bin/bash
#SBATCH --job-name=ahlf-finetune
#SBATCH --output=slurm_%j.out
#SBATCH --time=12:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --partition=gpu-batch
#SBATCH --gpus=1
#SBATCH --constrain="GPU_SKU:V100&ARCH:X86"
#SBATCH --account=sci-renard-usi-grabber

# Activate conda environment
eval "$(conda shell.bash hook)"
conda activate ahlf_interpretation_env

python finetuning.py \
    model/alpha_model_weights.hdf5 \
    model/finetuned_alpha_model_weights.hdf5 \
    ./training

# Use srun to get an interactive GPU session with the same resources:
# srun -A sci-renard-usi-grabber -p gpu-interactive --gres=gpu:1 --cpus-per-task=4 --mem=16G -C "GPU_SKU:V100&ARCH:X86" --pty bash